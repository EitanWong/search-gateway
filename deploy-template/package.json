{
  "name": "search-gateway-worker-template",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker search/fetch gateway template.",
  "scripts": {
    "build": "node --check src/index.js && node --check scripts/bootstrap-github-actions.mjs",
