# Optional local/provider configuration.
# Copy this file to .dev.vars for local `npm run dev` usage.
#
# Zero-config deployment works without any secrets. In that default mode,
# /search and /fetch are open. To require bearer auth after deployment,
# set SEARCH_GATEWAY_TOKEN as a Cloudflare Worker secret.

# SEARCH_GATEWAY_TOKEN=
# SEARXNG_URL=https://your-searxng.example.com
# SEARXNG_CATEGORIES=general
# SEARXNG_SAFESEARCH=0
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev

# Optional best-effort in-worker limiter. Requires adding a KV binding named
# SEARCH_RATE_LIMIT_KV in wrangler.json or in the Cloudflare dashboard.
# SEARCH_RATE_LIMIT_PER_MINUTE=60
